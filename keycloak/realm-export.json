{
  "id": "sber-realm",
  "realm": "sber-realm",
  "displayName": "SberInfo",
  "enabled": true,
  "loginTheme": "sberinfo",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "verifyEmail": false,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "sberinfo-spa",
      "name": "SberInfo Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8085/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8085"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "api-gateway",
      "name": "API Gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "api-gateway-secret-change-me",
      "standardFlowEnabled": true,
      "bearerOnly": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/keycloak",
        "http://localhost:8085/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:8085"
      ]
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\"},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]}},{\"name\":\"firstName\",\"displayName\":\"Имя\",\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"lastName\",\"displayName\":\"Фамилия\",\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"phone\",\"displayName\":\"Телефон\",\"required\":{},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}}]}"
          ]
        }
      }
    ]
  }
}
