# PostgreSQL: Deal Database
POSTGRES_DEAL_DB=deal_db
POSTGRES_DEAL_USER=your_deal_db_user
POSTGRES_DEAL_PASSWORD=your_deal_db_password

# PostgreSQL: Keycloak Database
POSTGRES_KEYCLOAK_DB=keycloak_db
POSTGRES_KEYCLOAK_USER=your_keycloak_db_user
POSTGRES_KEYCLOAK_PASSWORD=your_keycloak_db_password

# Keycloak Admin
KEYCLOAK_ADMIN_USER=your_keycloak_admin_user
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password

# Keycloak OAuth2 Client Secret
KC_CLIENT_SECRET=change_me_to_a_strong_secret

# Grafana Admin
GRAFANA_ADMIN_USER=your_grafana_admin_user
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password
